# =============================================================================
# DFIR-Updater .gitignore
# =============================================================================
# This file controls which files are tracked in the DFIR-Updater Git repository.
# The goal is to version-control the updater framework (scripts, config, docs)
# while excluding machine-specific, temporary, and backup artifacts.
# =============================================================================

# ── Backup files created during tool updates ─────────────────────────────────
*.bak_*

# ── Machine-specific scan output ─────────────────────────────────────────────
scan-manifest.json

# ── Setup/bootstrap logs (generated per-run on target drives) ────────────────
setup-log.txt

# ── Temporary files ──────────────────────────────────────────────────────────
*.tmp
*.temp
~$*

# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS metadata files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Log files ────────────────────────────────────────────────────────────────
*.log

# ── Exported reports/CSV files ─────────────────────────────────────────────
exports/

# ── Build output ───────────────────────────────────────────────────────────
dist/

# ── Forensic reports (machine-specific) ───────────────────────────────────
forensic-reports/

# ── IDE / Editor settings (user-specific, not project config) ────────────
.vscode/
.idea/
*.code-workspace
*.suo
*.user
*.sln.docstates

# ── Claude Code local config ──────────────────────────────────────────────
.claude/

# ── Forensic Mode artifacts ──────────────────────────────────────────────────
# Cleanup reports are machine-specific and should not be tracked
cleanup-reports/
write-protect-logs/

# The lockfile state is per-machine — do not track
FORENSIC_MODE

# ── Downloaded binaries (should not be committed) ────────────────────────
# Executables in the repo root are likely downloaded tools, not source
/*.exe
/*.msi
/*.zip

# ── PSScriptAnalyzer output ──────────────────────────────────────────────
PSScriptAnalyzerResults.xml
PSScriptAnalyzerResults.json

# ── Certificate and key files (security) ─────────────────────────────────
*.pfx
*.pem
*.key
*.cer

# ── Environment and secrets files ────────────────────────────────────────
.env
.env.*
secrets.json

# =============================================================================
# DO NOT ignore these files -- they are part of the framework:
#   - tools-config.json     (the tool registry)
#   - *.ps1                 (all PowerShell scripts)
#   - README.md, README.txt (documentation)
#   - Launch-Updater.bat    (batch launcher)
# =============================================================================
